{
  "name": "rego-server",
  "version": "1.0.0",
  "description": "Rego marketplace API server",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts start",
    "dev": "nodemon --exec tsx server.ts dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:wipe": "tsx scripts/db-wipe.ts",
    "db:cleanup": "tsx scripts/db-cleanup.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "bcrypt": "^5.1.0",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.0.3",
    "express": "^4.17.1",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.17.2",
    "file-type": "^16.5.4",
    "helmet": "^8.1.0",
    "mongodb": "^7.1.0",
    "mongoose": "^8.23.0",
    "multer": "^1.4.3",
    "multer-s3": "^3.0.0",
    "nodemailer": "^6.9.4",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "password-validator": "^5.3.0",
    "socket.io": "^4.6.2",
    "validator": "^13.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
